#!/usr/bin/env bash
# Post-commit hook: keep local Docker deployment in sync with the repo.
#
# Syncs plugins/ to the external Docker plugin directory, then rebuilds and
# restarts the serve + mcp containers so they pick up code changes.
#
# Install: cp .githooks/post-commit .git/hooks/post-commit
#   (or run: .githooks/install-hooks.sh)

set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"

# ── Sync plugins to external Docker directory ──
EXTERNAL_PLUGINS="C:/Docker/openchronicle/plugins"
if [ -d "$EXTERNAL_PLUGINS" ]; then
    echo "[post-commit] Syncing plugins to ${EXTERNAL_PLUGINS}"
    # Clean destination (except .git artifacts) and copy fresh
    find "$EXTERNAL_PLUGINS" -mindepth 1 -maxdepth 1 -exec rm -rf {} +
    cp -r "${REPO_ROOT}/plugins/"* "$EXTERNAL_PLUGINS/" 2>/dev/null || true
    # Remove __pycache__ from the copy
    find "$EXTERNAL_PLUGINS" -type d -name __pycache__ -exec rm -rf {} + 2>/dev/null || true
    echo "[post-commit] Plugin sync complete"
fi

# ── Rebuild and restart local Docker containers ──
COMPOSE_LOCAL="${REPO_ROOT}/docker-compose.local.yml"
if [ -f "$COMPOSE_LOCAL" ]; then
    echo "[post-commit] Rebuilding Docker containers"
    (
        cd "$REPO_ROOT"
        docker compose -f docker-compose.yml -f "$COMPOSE_LOCAL" build --quiet serve mcp 2>/dev/null
        docker compose -f docker-compose.yml -f "$COMPOSE_LOCAL" up -d serve mcp 2>/dev/null
    )
    echo "[post-commit] Docker containers rebuilt and restarted"
fi
