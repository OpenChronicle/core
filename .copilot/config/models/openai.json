{
  "provider": "openai",
  "display_name": "OpenAI GPT-4",
  "enabled": true,
  "api_config": {
    "endpoint": "https://api.openai.com/v1/chat/completions",
    "model": "gpt-4",
    "api_key_env": "OPENAI_API_KEY",
    "organization_env": "OPENAI_ORGANIZATION"
  },
  "capabilities": {
    "text_generation": true,
    "image_generation": false,
    "function_calling": true,
    "streaming": true
  },
  "limits": {
    "max_tokens": 4096,
    "context_window": 8192,
    "rate_limit_rpm": 3000,
    "rate_limit_tpm": 40000
  },
  "content_filtering": {
    "supports_nsfw": false,
    "allowed_content": ["general", "fantasy", "sci-fi", "mystery"],
    "blocked_content": ["explicit", "graphic_violence", "hate_speech"],
    "safety_level": "strict"
  },
  "generation_params": {
    "temperature": 0.7,
    "top_p": 0.9,
    "frequency_penalty": 0.0,
    "presence_penalty": 0.0,
    "max_tokens": 1000
  },
  "cost_tracking": {
    "input_cost_per_1k_tokens": 0.01,
    "output_cost_per_1k_tokens": 0.03,
    "currency": "USD"
  },
  "retry_config": {
    "max_retries": 3,
    "retry_delay": 1.0,
    "exponential_backoff": true,
    "retry_on_errors": ["timeout", "rate_limit", "server_error"]
  },
  "monitoring": {
    "track_usage": true,
    "log_requests": true,
    "alert_on_errors": true,
    "performance_metrics": true
  },
  "integration_notes": "Primary model for high-quality text generation. Use for important scenes and character development."
}
