{
  "provider": "ollama",
  "display_name": "Ollama Local LLM",
  "enabled": true,
  "api_config": {
    "endpoint": "http://localhost:11434/api/generate",
    "model": "llama3.2:3b",
    "timeout": 120,
    "stream": true
  },
  "capabilities": {
    "text_generation": true,
    "image_generation": false,
    "function_calling": false,
    "streaming": true
  },
  "limits": {
    "max_tokens": 2048,
    "context_window": 4096,
    "rate_limit_rpm": null,
    "rate_limit_tpm": null
  },
  "content_filtering": {
    "supports_nsfw": true,
    "allowed_content": ["general", "fantasy", "sci-fi", "mystery", "mature"],
    "blocked_content": ["illegal", "harmful"],
    "safety_level": "moderate"
  },
  "generation_params": {
    "temperature": 0.8,
    "top_p": 0.9,
    "top_k": 40,
    "repeat_penalty": 1.1,
    "num_predict": 1000
  },
  "cost_tracking": {
    "input_cost_per_1k_tokens": 0.0,
    "output_cost_per_1k_tokens": 0.0,
    "currency": "USD",
    "notes": "Local model - no API costs"
  },
  "retry_config": {
    "max_retries": 2,
    "retry_delay": 2.0,
    "exponential_backoff": false,
    "retry_on_errors": ["timeout", "connection_error"]
  },
  "monitoring": {
    "track_usage": true,
    "log_requests": false,
    "alert_on_errors": false,
    "performance_metrics": true
  },
  "hardware_requirements": {
    "min_ram_gb": 4,
    "recommended_ram_gb": 8,
    "gpu_acceleration": true,
    "cpu_threads": 4
  },
  "integration_notes": "Local model for privacy-focused deployments and cost-effective generation. Good for NSFW content routing."
}
