.vscode/
.idea/
*.swp
*.swo
*~
# Include essential copilot config, exclude development files
.copilot/tasks/
.copilot/patterns/
.copilot/examples/
.copilot/architecture/
.copilot/config/
.copilot/testing/

# OS
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Development and testing
.env*
.env.local
.env.development
.env.production
# tests/ - commenting out to include tests in Docker build
.pytest_cache/
.coverage
.nyc_output
htmlcov/
.tox/
.nox/
.hypothesis/
pytest.ini
tox.ini

# Test artifacts - comprehensive exclusion
test_cleanup_*
temp_test*
temp_storypack_*
storage/temp/test_data/
storage/temp/test_stories/
storage/storypacks/test_*
storage/storypacks/*test*
storage/storypacks/cli_test*

# Logs and runtime data
*.log
*.jsonl
logs/
storage/temp/
storage/data/*.db
storage/data/memory.db
storage/**/openchronicle.db
storage/backups/
storage/data/performance/
storage/data/runtime/
storage/data/profiles/
# Include core storage structure but exclude data files
storage/
!storage/.gitkeep

# Documentation (include live docs from root, exclude subfolders)
docs/*/
docs/consolidation/
docs/archive/
documentation_archive_*/
analysis/
*.old
*.ignoreme
# Keep essential documentation
!README.md
!ARCHITECTURE_GUIDE.md
!PROJECT_WORKFLOW_OVERVIEW.md

# Docker
Dockerfile*
docker-compose*
.dockerignore

# Build artifacts and dependencies
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Configuration backups
config/models.json.backup.*

# Import staging directory - ignore contents but keep README
import/*
!import/README.md

# Obsolete files
*.old.ignoreme
# Preserve foundational README for project history
!README.md.old.ignoreme
