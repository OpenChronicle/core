## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.
##
## Get latest from https://github.com/github/gitignore/blob/main/VisualStudio.gitignore

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual environments
.venv/
.env/
venv/
env/
ENV/
env.bak/
venv.bak/

# OpenChronicle specific
*.env
.env.local
.env.production
storage/*/openchronicle.db
storage/**/openchronicle.db
storage/*/logs/
storage/*/exports/
storage/temp/
storage/data/memory.db
storage/data/*.db
*.jsonl
*.log
bandit-report.json
logs/
demo_storage/
config/backups/
# Storage data (runtime/generated) — keep demo storypack and README only
storage/characters/
storage/profiles/
storage/temp/
storage/data/
storage/narrative_*/
storage/response_intelligence/
storage/scenes/
storage/import_analysis.json
storage/performance_baseline.json
storage/phase1_health_report.json
storage/performance_metrics.db
# Character backups anywhere under storage
storage/**/backups/


# Analysis and development folders
!core/analysis/
!core/analysis/**
logs/
tests/logs/
storage/temp/
storage/data/performance/
storage/data/runtime/
storage/data/profiles/
storage/data/memory.db
storage/data/*.db
storage/backups/

# Documentation archives
documentation_archive_*/
docs/archive/
docs/consolidation/

# Test artifacts - comprehensive exclusion
test_cleanup_*
temp_test*
temp_storypack_*
storage/temp/test_data/test_story_*/
storage/temp/test_data/perf_test_*/
storage/temp/test_stories/
storage/storypacks/test_*
storage/storypacks/*test*
storage/storypacks/cli_test*

# Import staging directory - ignore contents but keep README
import/*
!import/README.md

# Obsolete files
*.old.ignoreme
# Preserve foundational README for project history
!README.md.old.ignoreme

# Development notes and temporary files
.github/*.txt
.github/CHAOS_SAGA_PROTOTYPE_ANALYSIS.md
.github/CLEAN_APPROACH_COMPLETE.md

# Configuration backups
config/models.json.backup.*

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# User-specific files (MonoDevelop/Xamarin Studio)
*.userprefs

# Mono auto generated files
mono_crash.*

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Ww][Ii][Nn]32/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
[Aa][Rr][Mm]64[Ee][Cc]/
bld/
[Oo]bj/
[Oo]ut/
[Ll]og/
[Ll]ogs/

# Build results on 'Bin' directories
**/[Bb]in/*
# Uncomment if you have tasks that rely on *.refresh files to move binaries
# (https://github.com/github/gitignore/pull/3736)
#!**/[Bb]in/*.refresh

# Visual Studio 2015/2017 cache/options directory
.vs/
# Uncomment if you have tasks that create the project's static files in wwwroot
#wwwroot/

# Visual Studio 2017 auto generated files
Generated\ Files/

# MSTest test Results
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*
*.trx

# NUnit
*.VisualState.xml
TestResult.xml
nunit-*.xml

# Approval Tests result files
*.received.*

# Build Results of an ATL Project
[Dd]ebugPS/
[Rr]eleasePS/
dlldata.c

# Benchmark Results
BenchmarkDotNet.Artifacts/

# .NET Core
project.lock.json
project.fragment.lock.json
artifacts/

# ASP.NET Scaffolding
ScaffoldingReadMe.txt

# StyleCop
StyleCopReport.xml

