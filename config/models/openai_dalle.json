{
  "provider": "openai_dalle",
  "display_name": "OpenAI DALL-E",
  "enabled": true,
  "type": "image_generation",
  "api_config": {
    "model_name": "dall-e-3",
    "base_url": "https://api.openai.com/v1/images/generations",
    "api_key": "",
    "api_key_env": "OPENAI_API_KEY",
    "organization": "",
    "organization_env": "OPENAI_ORGANIZATION"
  },
  "capabilities": {
    "text_generation": false,
    "image_generation": true,
    "function_calling": false,
    "streaming": false,
    "vision": false
  },
  "image_capabilities": {
    "supported_sizes": [
      "1024x1024",
      "1792x1024", 
      "1024x1792"
    ],
    "supported_formats": ["png"],
    "max_prompt_length": 4000,
    "style_support": true,
    "quality_levels": ["standard", "hd"]
  },
  "limits": {
    "max_images_per_request": 1,
    "rate_limit_rpm": 50,
    "cost_per_image_1024": 0.040,
    "cost_per_image_1792": 0.080
  },
  "content_filtering": {
    "supports_nsfw": false,
    "content_policy_enforcement": true,
    "automatic_moderation": true
  },
  "fallback_models": [
    "stability_ai",
    "mock_image"
  ],
  "priority": 1,
  "quality_score": 9,
  "speed_score": 7,
  "cost_score": 6
}
