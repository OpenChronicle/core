{
  "provider": "google",
  "display_name": "Google Gemini",
  "enabled": true,
  "type": "google",
  "api_config": {
    "model_name": "gemini-pro",
    "base_url": "https://generativelanguage.googleapis.com/v1beta",
    "api_key": "",
    "api_key_env": "GOOGLE_API_KEY",
    "version": "v1beta"
  },
  "capabilities": {
    "text_generation": true,
    "image_generation": false,
    "function_calling": true,
    "streaming": true,
    "vision": true
  },
  "limits": {
    "max_tokens": 8192,
    "context_window": 32768,
    "rate_limit_rpm": 60,
    "rate_limit_tpm": 32000,
    "cost_per_1k_input": 0.0005,
    "cost_per_1k_output": 0.0015
  },
  "content_filtering": {
    "supports_nsfw": false,
    "allowed_content": ["general", "fantasy", "sci-fi", "mystery", "creative", "educational", "analysis"],
    "blocked_content": ["explicit", "graphic_violence", "hate_speech", "illegal"],
    "safety_level": "strict"
  },
  "generation_params": {
    "temperature": 0.7,
    "top_p": 0.9,
    "top_k": 40,
    "max_tokens": 8192
  },
  "retry_config": {
    "max_retries": 3,
    "retry_delay": 1.0,
    "exponential_backoff": true,
    "retry_on_errors": ["timeout", "rate_limit", "server_error", "connection_error"]
  },
  "monitoring": {
    "track_usage": true,
    "log_requests": true,
    "alert_on_errors": true,
    "performance_metrics": true
  },
  "available_models": [
    {
      "name": "gemini-pro",
      "context_window": 32768,
      "max_tokens": 8192,
      "cost_per_1k_input": 0.0005,
      "cost_per_1k_output": 0.0015
    },
    {
      "name": "gemini-pro-vision",
      "context_window": 16384,
      "max_tokens": 4096,
      "cost_per_1k_input": 0.0005,
      "cost_per_1k_output": 0.0015
    },
    {
      "name": "gemini-1.5-pro",
      "context_window": 1048576,
      "max_tokens": 8192,
      "cost_per_1k_input": 0.0005,
      "cost_per_1k_output": 0.0015
    }
  ],
  "integration_notes": "Excellent multimodal capabilities and long context windows. Strong reasoning abilities.",
  "health_check": {
    "endpoint": "https://generativelanguage.googleapis.com/v1beta/models",
    "method": "GET",
    "expected_status": 200,
    "timeout": 10
  }
}
