  "fallback_behavior": {
    "max_fallback_attempts": 3,
    "fallback_delay_seconds": 1,
    "log_fallback_usage": true,
    "fail_on_all_fallbacks": true,
    "retry_on_errors": [
      "timeout",
      "rate_limit",
      "server_error",
      "connection_error"
    ]
  },
  "performance": {
    "max_concurrent_requests": 3,
    "timeout_seconds": 30,
    "rate_limit_buffer": 0.1,
    "health_check_interval": 300
  }
