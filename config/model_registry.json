        "supports_nsfw": false,
        "content_types": [
          "general",
          "fantasy",
          "sci-fi",
          "mystery",
          "creative",
          "analysis"
        ],
        "description": "Anthropic Claude models - excellent for analysis and creative writing",
        "fallbacks": [
          "groq",
          "ollama",
          "mock"
        ]
      }
    ],
    "standard_priority": [
      {
        "name": "groq",
        "provider": "groq",
        "enabled": true,
        "priority": 4,
        "model_name": "llama-3.1-70b-versatile",
        "supports_nsfw": false,
        "content_types": [
          "general",
          "fantasy",
          "sci-fi",
          "creative"
        ],
        "description": "Groq fast inference - good for quick responses",
        "fallbacks": [
          "ollama",
          "mock"
        ],
        "config": {
          "timeout": 15
        }
      },
      {
        "name": "gemini",
        "provider": "gemini",
        "enabled": true,
        "priority": 5,
        "model_name": "gemini-1.5-flash",
        "supports_nsfw": false,
        "content_types": [
          "general",
          "fantasy",
          "sci-fi",
          "analysis"
        ],
        "description": "Google Gemini models - good for analysis and general tasks",
        "fallbacks": [
          "ollama",
          "mock"
        ]
      },
      {
        "name": "cohere",
        "provider": "cohere",
        "enabled": true,
        "priority": 6,
        "model_name": "command-r-plus",
        "supports_nsfw": false,
        "content_types": [
          "general",
          "creative"
        ],
        "description": "Cohere Command models - good for creative tasks",
        "fallbacks": [
          "ollama",
          "mock"
        ]
      },
      {
        "name": "mistral",
        "provider": "mistral",
        "enabled": true,
        "priority": 7,
        "model_name": "mistral-large-latest",
        "supports_nsfw": false,
        "content_types": [
          "general",
          "fantasy",
          "sci-fi",
          "creative"
        ],
        "description": "Mistral AI models - European alternative",
        "fallbacks": [
          "ollama",
          "mock"
        ]
      }
    ],
    "testing": [
      {
        "name": "mock",
        "provider": "mock",
        "enabled": true,
        "priority": 99,
        "model_name": "mock-model",
        "supports_nsfw": true,
        "content_types": [
          "general",
          "fantasy",
          "sci-fi",
          "mystery",
          "creative",
          "mature",
          "testing"
        ],
        "description": "Mock model for testing and development",
        "fallbacks": []
      }
    ]
  },
  "image_models": {
    "primary": [
      {
        "name": "openai_dalle",
        "provider": "openai",
        "enabled": true,
        "priority": 1,
        "model_name": "dall-e-3",
        "supports_nsfw": false,
        "content_types": [
          "character_portraits",
          "scene_images",
          "general_images"
        ],
        "description": "OpenAI DALL-E models - high quality image generation",
        "fallbacks": [
          "stability_ai",
          "mock_image"
        ],
        "config": {
          "size": "1024x1024",
          "quality": "standard",
          "style": "vivid"
        }
      },
      {
        "name": "stability_ai",
        "provider": "stability",
        "enabled": false,
        "priority": 2,
        "model_name": "stable-diffusion-xl-1024-v1-0",
        "supports_nsfw": true,
        "content_types": [
          "character_portraits",
          "scene_images",
          "general_images",
          "artistic"
        ],
        "description": "Stability AI models - flexible image generation with style control",
        "fallbacks": [
          "mock_image"
        ],
        "config": {
          "width": 1024,
          "height": 1024,
          "steps": 30
        }
      }
    ],
    "testing": [
      {
        "name": "mock_image",
        "provider": "mock",
        "enabled": true,
        "priority": 99,
        "model_name": "mock-image-model",
        "supports_nsfw": true,
        "content_types": [
          "character_portraits",
          "scene_images",
          "general_images",
          "testing"
        ],
        "description": "Mock image generator for testing and development",
        "fallbacks": [],
        "config": {
          "size": "1024x1024"
        }
      }
    ]
  },
  "content_routing": {
    "nsfw_content": {
      "allowed_models": [
        "ollama",
        "stability_ai",
        "mock",
        "mock_image"
      ],
      "default_model": "ollama",
      "auto_select": true,
      "recommendation_criteria": {
        "prefer_local": true,
        "privacy_weight": 0.8,
        "quality_weight": 0.2
      }
    },
    "safe_content": {
      "allowed_models": [
        "openai",
        "anthropic",
        "groq",
        "gemini",
        "cohere",
        "mistral",
        "openai_dalle"
      ],
      "default_model": "openai",
      "auto_select": true,
      "recommendation_criteria": {
        "quality_weight": 0.5,
        "speed_weight": 0.3,
        "cost_weight": 0.2
      }
    },
    "analysis_tasks": {
      "allowed_models": [
        "anthropic",
        "openai",
        "gemini"
      ],
      "default_model": "anthropic",
      "auto_select": true,
      "recommendation_criteria": {
        "reasoning_capability": 0.6,
        "accuracy_weight": 0.4
      }
    },
    "creative_tasks": {
      "allowed_models": [
        "openai",
        "anthropic",
        "cohere",
        "mistral",
        "ollama"
      ],
      "default_model": "anthropic",
      "auto_select": true,
      "recommendation_criteria": {
        "creativity_score": 0.5,
        "coherence_weight": 0.3,
        "user_preference": 0.2
      }
    },
    "fast_responses": {
      "allowed_models": [
        "groq",
        "ollama"
      ],
      "default_model": "groq",
      "auto_select": true,
      "recommendation_criteria": {
        "response_time": 0.8,
        "availability": 0.2
      }
    },
    "by_capability": {
      "code_generation": [
        "ollama",
        "openai",
        "anthropic"
      ],
      "long_context": [
        "anthropic",
        "gemini",
        "ollama"
      ],
      "multilingual": [
        "openai",
        "anthropic",
        "gemini",
        "mistral"
      ],
      "function_calling": [
        "openai",
        "anthropic",
        "mistral"
      ],
      "vision": [
        "openai",
        "anthropic",
        "gemini"
      ]
    }
  },
  "fallback_chains": {
    "primary_text": [
      "ollama",
      "openai",
      "anthropic",
      "groq",
      "mock"
    ],
    "nsfw_text": [
      "ollama",
      "mock"
    ],
    "analysis_text": [
      "anthropic",
      "openai",
      "gemini",
      "mock"
    ],
    "creative_text": [
      "anthropic",
      "openai",
      "cohere",
      "ollama",
      "mock"
    ],
    "fast_text": [
      "groq",
      "ollama",
      "openai",
      "mock"
    ],
    "primary_image": [
      "openai_dalle",
      "stability_ai",
      "mock_image"
    ],
    "nsfw_image": [
      "stability_ai",
      "mock_image"
    ],
    "artistic_image": [
      "stability_ai",
      "openai_dalle",
      "mock_image"
    ]
  },
  "performance_tuning": {
    "concurrent_limits": {
      "openai": 3,
      "anthropic": 2,
      "groq": 5,
      "ollama": 1,
      "gemini": 3,
      "cohere": 3,
      "mistral": 3,
      "stability": 1
    },
    "rate_limits": {
      "openai": {
        "requests_per_minute": 500,
        "tokens_per_minute": 200000
      },
      "anthropic": {
        "requests_per_minute": 50,
        "tokens_per_minute": 40000
      },
      "groq": {
        "requests_per_minute": 30,
        "tokens_per_minute": 6000
      },
      "gemini": {
        "requests_per_minute": 60,
        "tokens_per_minute": 32000
      },
      "cohere": {
        "requests_per_minute": 100,
        "tokens_per_minute": 20000
      },
      "mistral": {
        "requests_per_minute": 100,
        "tokens_per_minute": 20000
      }
    },
    "health_checks": {
      "enabled": true,
      "interval_seconds": 300,
      "timeout_seconds": 10,
      "failure_threshold": 3,
      "success_threshold": 2
    }
  }
}