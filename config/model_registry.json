{
  "schema_version": "3.0.0",
  "metadata": {
    "name": "OpenChronicle Model Registry",
    "description": "Centralized configuration for all AI models and providers",
    "last_updated": "2025-07-24",
    "maintainer": "OpenChronicle Team"
  },
  "defaults": {
    "text_model": "ollama",
    "analyzer_model": "ollama",
    "image_model": "openai_dalle"
  },
  "global_settings": {
    "enable_fallbacks": true,
    "enable_health_checks": true,
    "enable_logging": true,
    "intelligent_routing": {
      "enabled": true,
      "learning_mode": true,
      "user_feedback_weight": 0.3,
      "performance_history_days": 7,
      "recommendation_confidence_threshold": 0.75,
      "auto_switch_on_failure": true,
      "preserve_user_overrides": true,
      "runtime_state_file": "storage/runtime/runtime_state.json"
    }
  },
  "environment_config": {
    "providers": {
      "ollama": {
        "base_url_env": "OLLAMA_HOST",
        "default_base_url": "http://localhost:11434",
        "api_key_env": null,
        "timeout": 120,
        "health_check_enabled": true
      },
      "openai": {
        "base_url_env": "OPENAI_BASE_URL",
        "default_base_url": "https://api.openai.com/v1",
        "api_key_env": "OPENAI_API_KEY",
        "timeout": 30,
        "health_check_enabled": true
      },
      "anthropic": {
        "base_url_env": "ANTHROPIC_BASE_URL",
        "default_base_url": "https://api.anthropic.com",
        "api_key_env": "ANTHROPIC_API_KEY",
        "timeout": 30,
        "health_check_enabled": true
      },
      "groq": {
        "base_url_env": "GROQ_BASE_URL",
        "default_base_url": "https://api.groq.com/openai/v1",
        "api_key_env": "GROQ_API_KEY",
        "timeout": 15,
        "health_check_enabled": true
      },
      "gemini": {
        "base_url_env": "GEMINI_BASE_URL",
        "default_base_url": "https://generativelanguage.googleapis.com/v1beta",
        "api_key_env": "GOOGLE_API_KEY",
        "timeout": 30,
        "health_check_enabled": true
      },
      "cohere": {
        "base_url_env": "COHERE_BASE_URL",
        "default_base_url": "https://api.cohere.ai/v1",
        "api_key_env": "COHERE_API_KEY",
        "timeout": 30,
        "health_check_enabled": true
      },
      "mistral": {
        "base_url_env": "MISTRAL_BASE_URL",
        "default_base_url": "https://api.mistral.ai/v1",
        "api_key_env": "MISTRAL_API_KEY",
        "timeout": 30,
        "health_check_enabled": true
      },
      "stability": {
        "base_url_env": "STABILITY_BASE_URL",
        "default_base_url": "https://api.stability.ai/v1",
        "api_key_env": "STABILITY_API_KEY",
        "timeout": 60,
        "health_check_enabled": true
      }
    },
    "defaults": {
      "timeout": 30,
      "max_tokens": 2048,
      "temperature": 0.7,
      "max_retries": 3,
      "retry_delay": 1.0,
      "concurrent_requests": 3,
      "enable_logging": true,
      "enable_fallbacks": true
    },
    "discovery": {
      "ollama": {
        "enabled": true,
        "auto_discovery": false,
        "discovery_interval": 300,
        "include_model_sizes": true,
        "detect_capabilities": true
      }
    }
  },
  "text_models": {
    "high_priority": [
      {
        "name": "ollama",
        "provider": "ollama",
        "enabled": true,
        "priority": 1,
        "model_name": "llama3.2:latest",
        "supports_nsfw": true,
        "content_types": [
          "general",
          "fantasy",
          "sci-fi",
          "mystery",
          "creative",
          "mature"
        ],
        "description": "Local Ollama models - privacy-focused, supports NSFW",
        "fallbacks": [
          "groq",
          "anthropic",
          "mock"
        ],
        "config": {
          "max_tokens": 4096,
          "temperature": 0.8
        },
        "auto_management": {
          "auto_select": true,
          "recommendation_weight": {
            "performance": 0.3,
            "cost": 0.2,
            "quality": 0.4,
            "availability": 0.1
          },
          "auto_disable_threshold": {
            "response_time_ms": 30000,
            "error_rate": 0.1,
            "consecutive_failures": 3
          },
          "auto_enable_conditions": {
            "health_restored_duration": 300,
            "success_rate_required": 0.95
          }
        }
      },
      {
        "name": "openai",
        "provider": "openai",
        "enabled": true,
        "priority": 2,
        "model_name": "gpt-4o-mini",
        "supports_nsfw": false,
        "content_types": [
          "general",
          "fantasy",
          "sci-fi",
          "mystery",
          "creative",
          "analysis"
        ],
        "description": "OpenAI GPT models - high quality, general purpose",
        "fallbacks": [
          "anthropic",
          "groq",
          "ollama",
          "mock"
        ]
      },
      {
        "name": "anthropic",
        "provider": "anthropic",
        "enabled": true,
        "priority": 3,
