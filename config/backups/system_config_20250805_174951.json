{
  "performance": {
    "max_concurrent_requests": 10,
    "request_timeout_seconds": 30,
    "memory_cache_size_mb": 512,
    "database_connection_pool_size": 10,
    "async_batch_size": 100,
    "enable_request_caching": true,
    "cache_ttl_seconds": 3600
  },
  "model": {
    "default_text_model": "gpt-3.5-turbo",
    "default_image_model": "dall-e-3",
    "model_fallback_enabled": true,
    "max_retries": 3,
    "retry_delay_seconds": 1.0,
    "context_window_buffer": 500,
    "temperature": 0.7,
    "max_tokens": 4000
  },
  "database": {
    "database_path": "storage",
    "backup_enabled": true,
    "backup_interval_hours": 24,
    "auto_vacuum_enabled": true,
    "checkpoint_interval_minutes": 60,
    "max_connections": 10,
    "query_timeout_seconds": 30
  },
  "security": {
    "enable_api_key_rotation": false,
    "max_request_rate_per_minute": 100,
    "enable_input_sanitization": true,
    "log_sensitive_data": false,
    "enable_audit_logging": true,
    "session_timeout_minutes": 30
  },
  "logging": {
    "log_level": "INFO",
    "log_rotation_size_mb": 10,
    "log_backup_count": 10,
    "enable_contextual_logging": true,
    "enable_model_interaction_logging": true,
    "log_retention_days": 30,
    "enable_performance_logging": true
  },
  "storage": {
    "base_storage_path": "storage",
    "scene_storage_path": "storage/scenes",
    "character_storage_path": "storage/characters",
    "memory_storage_path": "storage/memory",
    "backup_storage_path": "storage/backups",
    "max_storage_size_gb": 10,
    "enable_compression": true
  },
  "config_version": "2.0",
